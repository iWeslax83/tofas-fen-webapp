# Client environment variables. Copy to client/.env for local dev; the defaults
# below are already correct for `npm run dev`.
#
# BUILD TIME, NOT RUN TIME. Vite inlines these into the JS bundle when
# `vite build` runs. They must be set in the build environment (CI env vars,
# Vercel project settings, Docker `ARG`). Setting them on a running container
# or host does nothing -- the values are already baked into the shipped bundle.
#
# NEVER put a secret in a VITE_* variable. Everything here is readable by
# anyone who opens devtools. Secrets belong in server/.env.

# Base URL of the backend API.
#
# REQUIRED for production builds. If it is missing, the app throws on boot and
# renders a completely blank page -- no error UI, nothing. In dev it falls back
# to the local server, so a missing value only bites once you build for prod.
#
# Local:      http://localhost:3001
# Production: https://api.your-domain.com   (no trailing slash)
VITE_API_URL=http://localhost:3001

# Sentry DSN for frontend error tracking. Optional -- leave empty to disable.
# Sentry -> your project -> Settings -> Client Keys (DSN)
VITE_SENTRY_DSN=

# --- Not currently read by the app -------------------------------------------
# VITE_WS_URL and VITE_APP_ENV are still plumbed through docker-compose, the
# k8s manifests and client/Dockerfile, but nothing under client/src reads them.
# There is currently no WebSocket client at all -- the server runs a WS server
# (server/src/utils/websocket.ts) that the frontend never connects to. Left here
# so the existing deploy configs stay self-explanatory; safe to ignore.
# VITE_WS_URL=ws://localhost:3001
# VITE_APP_ENV=development
