# Production Environment Variables Template
# Copy this file to .env.production and update the values

NODE_ENV=production

# Database Configuration
MONGODB_URI=mongodb://admin:YOUR_MONGO_PASSWORD@mongodb:27017/tofas-fen?authSource=admin

# Server Configuration
PORT=3001
BACKEND_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
WS_URL=wss://yourdomain.com

# Security Configuration (CHANGE THESE IN PRODUCTION!)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=400
AUTH_RATE_LIMIT_MAX=5
UPLOAD_RATE_LIMIT_MAX=10

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/mov,application/pdf

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# MEB E-okul Integration (Optional)
MEB_EOKUL_BASE_URL=https://eokul.meb.gov.tr
MEB_EOKUL_API_KEY=your-meb-eokul-api-key
MEB_EOKUL_USERNAME=your-meb-eokul-username
MEB_EOKUL_PASSWORD=your-meb-eokul-password

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Monitoring Configuration
ENABLE_MONITORING=true
METRICS_PORT=9090

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Domain Configuration
DOMAIN=yourdomain.com
SUBDOMAIN=www

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Performance Configuration
MAX_CONNECTIONS=1000
KEEP_ALIVE_TIMEOUT=65000
REQUEST_TIMEOUT=30000

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Security Headers
HSTS_MAX_AGE=31536000
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ws: wss:;
