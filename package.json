{
  "name": "tofas-fen-webapp",
  "version": "1.0.0",
  "description": "Tofaş Fen Lisesi Bilgi Sistemi - Full Stack Web Application",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "start": "cd server && npm start",
    "start:server": "cd server && npm start",
    "start:client": "cd client && npm run preview",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "test": "npm run test:server && npm run test:client",
    "test:unit": "npm run test:server:unit && npm run test:client:unit",
    "test:integration": "npm run test:server:integration",
    "test:e2e": "npm run test:client:e2e",
    "test:coverage": "npm run test:server:coverage && npm run test:client:coverage",
    "test:server": "cd server && npm test",
    "test:server:unit": "cd server && npm run test:unit",
    "test:server:integration": "cd server && npm run test:integration",
    "test:server:coverage": "cd server && npm run test:coverage",
    "test:client": "cd client && npm test",
    "test:client:unit": "cd client && npm run test:unit",
    "test:client:e2e": "cd client && npm run test:e2e",
    "test:client:coverage": "cd client && npm run test:coverage",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:fix": "npm run lint:server:fix && npm run lint:client:fix",
    "lint:server": "cd server && npm run lint",
    "lint:server:fix": "cd server && npm run lint:fix",
    "lint:client": "cd client && npm run lint",
    "lint:client:fix": "cd client && npm run lint:fix",
    "type-check": "npm run type-check:server && npm run type-check:client",
    "type-check:server": "cd server && npm run type-check",
    "type-check:client": "cd client && npm run type-check",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "clean": "rm -rf server/dist client/dist server/node_modules client/node_modules node_modules",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "k8s:apply": "kubectl apply -f k8s/production/",
    "k8s:delete": "kubectl delete -f k8s/production/",
    "k8s:status": "kubectl get pods -n tofas-fen-prod",
    "seed": "cd server && npm run seed",
    "docs:serve": "cd docs && python -m http.server 8080",
    "docs:build": "cd docs && mkdocs build"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/mongoose": "^5.11.96",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.1",
    "framer-motion": "^12.23.12",
    "mongoose": "^8.16.4",
    "nodemailer": "^7.0.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-toastify": "^11.0.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express-session": "^1.18.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-toastify": "^4.0.2",
    "concurrently": "^8.2.2"
  }
}
