{
  "name": "tofas-fen-webapp",
  "version": "1.0.0",
  "description": "Tofaş Fen Lisesi Bilgi Sistemi - Full Stack Web Application",
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=server",
    "dev:client": "turbo run dev --filter=client",
    "start": "cd server && npm start",
    "start:server": "cd server && npm start",
    "start:client": "cd client && npm run preview",
    "build": "turbo run build",
    "build:server": "turbo run build --filter=server",
    "build:client": "turbo run build --filter=client",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "cd server && npm run test:integration",
    "test:e2e": "cd client && npm run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "test:server": "turbo run test --filter=server",
    "test:server:unit": "turbo run test:unit --filter=server",
    "test:server:integration": "cd server && npm run test:integration",
    "test:server:coverage": "turbo run test:coverage --filter=server",
    "test:client": "turbo run test --filter=client",
    "test:client:unit": "turbo run test:unit --filter=client",
    "test:client:e2e": "cd client && npm run test:e2e",
    "test:client:coverage": "turbo run test:coverage --filter=client",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:server": "turbo run lint --filter=server",
    "lint:server:fix": "turbo run lint:fix --filter=server",
    "lint:client": "turbo run lint --filter=client",
    "lint:client:fix": "turbo run lint:fix --filter=client",
    "type-check": "turbo run type-check",
    "type-check:server": "turbo run type-check --filter=server",
    "type-check:client": "turbo run type-check --filter=client",
    "clean": "rm -rf server/dist client/dist server/node_modules client/node_modules node_modules .turbo",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "k8s:apply": "kubectl apply -f k8s/production/",
    "k8s:delete": "kubectl delete -f k8s/production/",
    "k8s:status": "kubectl get pods -n tofas-fen-prod",
    "seed": "cd server && npm run seed",
    "docs:serve": "cd docs && python -m http.server 8080",
    "docs:build": "cd docs && mkdocs build",
    "generate-secrets": "node scripts/generate-secrets.js",
    "prepare-production": "node scripts/generate-secrets.js",
    "prepare": "husky || true",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "server/src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/mongoose": "^5.11.96",
    "@types/nodemailer": "^6.4.17",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.1",
    "framer-motion": "^12.23.12",
    "kubernetes": "^1.0.0",
    "mongoose": "^8.16.4",
    "nodemailer": "^8.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-toastify": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.7",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@types/express-session": "^1.18.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-toastify": "^4.0.2",
    "concurrently": "^8.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.0",
    "typescript-eslint": "^8.53.1"
  }
}
