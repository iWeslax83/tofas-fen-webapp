NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/tofas-fen
# MONGODB_AUTH_SOURCE=admin
# MONGODB_REPLICA_SET=

# Redis
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# JWT Secrets - MUST be at least 32 characters, generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64

# Encryption - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting (development - relaxed)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:5173

# VAPID Keys for Push Notifications - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# Monitoring (optional)
# LOG_LEVEL=info
# SENTRY_DSN=
# MONITORING_API_KEY=
# CSP_REPORT_URI=

# Cloudflare (optional)
# TRUST_CLOUDFLARE=false
