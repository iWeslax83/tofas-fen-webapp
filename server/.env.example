NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/tofas-fen
# MONGODB_AUTH_SOURCE=admin
# MONGODB_REPLICA_SET=
# MONGODB_TLS=true|false — defaults: true for mongodb+srv:// URIs and for
# NODE_ENV=production; false otherwise. Set explicitly to override.
#
# Running tests: the vitest suite ignores MONGODB_URI above and builds its own
# test database URI (see server/vitest.config.ts). To point it at a specific
# MongoDB (CI, or a local auth-less mongod), set TEST_MONGODB_URI, e.g.:
#   TEST_MONGODB_URI=mongodb://127.0.0.1:27017/tofas-fen-test npx vitest run

# Redis
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# JWT Secrets - MUST be at least 32 characters, generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64

# Encryption - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting (development - relaxed)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:5173

# SameSite policy for auth cookies. Defaults to `strict`.
#
# Set to `none` when the frontend and the API are on DIFFERENT domains --
# e.g. the app on *.vercel.app and the API on *.onrender.com. Those are
# separate sites, so every API call is cross-site, and the browser refuses to
# send a `strict`/`lax` cookie cross-site: login succeeds, no cookie is stored,
# and the next request comes back 401.
#
# `none` requires HTTPS (it forces the Secure flag on). It also gives up the
# browser's built-in CSRF protection, which is why it is not the default --
# the app's own double-submit csrfToken check is what covers you there.
#
# If you later put both behind one domain (app.example.com + api.example.com),
# remove this and go back to `strict`.
COOKIE_SAMESITE=strict

# VAPID Keys for Push Notifications - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# Monitoring (optional)
# LOG_LEVEL=info
# SENTRY_DSN=
# MONITORING_API_KEY=
# CSP_REPORT_URI=

# Cloudflare (optional)
# TRUST_CLOUDFLARE=false
